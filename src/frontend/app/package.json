{
  "name": "@openbook-studio/frontend-app",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node ../../../bin/frontend/clean.js",
    "watch:tailwind": "tailwindcss -i tailwind.css -o src/tailwind.css --watch",
    "watch:src": "node ../../../bin/frontend/watch.js",
    "watch": "npm run build:tailwind && conc -n tailwind,src -c auto \"npm run watch:tailwind\" \"npm run watch:src\"",
    "build:tailwind": "tailwindcss -i tailwind.css -o src/tailwind.css",
    "build:api:openbook": "openapi-typescript http://localhost:8000/api/schema/ -o ./src/backend/openapi/openbook.d.ts",
    "build:api:auth": "openapi-typescript http://localhost:8000/auth-api/openapi.json -o ./src/backend/openapi/auth.d.ts",
    "build:api": "npm run build:api:openbook && npm run build:api:auth",
    "build:src": "node ../../../bin/frontend/build.js",
    "build": "npm run build:tailwind && npm run build:api && npm run build:src",
    "lint": "eslint \"./**/*.{ts,tsx}\"",
    "lintfix": "eslint --fix \"./**/*.{ts,tsx}\"",
    "prettier": "prettier --ignore-path ../../.gitignore \"**/*.+(ts|tsx)\"",
    "format": "npm run prettier -- --write",
    "check": "npm run lint && tsc"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "bootstrap-icons": "^1.13.1",
    "daisyui": "^5.5.19",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "svelte-spa-router": "^5.0.1",
    "tailwindcss": "^4.2.4"
  }
}
