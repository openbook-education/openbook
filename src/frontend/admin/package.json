{
  "name": "@openbook-studio/frontend-admin",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.x",
  "scripts": {
    "clean": "node ../../../_scripts/frontend/clean.js",
    "watch": "node ../../../_scripts/frontend/watch.js",
    "build": "node ../../../_scripts/frontend/build.js",
    "lint": "eslint \"./**/*.{ts,tsx}\"",
    "lintfix": "eslint --fix \"./**/*.{ts,tsx}\"",
    "prettier": "prettier --ignore-path ../../.gitignore \"**/*.+(ts|tsx)\"",
    "format": "npm run prettier -- --write",
    "check": "npm run lint && tsc"
  },
  "dependencies": {
    "ckeditor5": "^47.7.1",
    "tiny-markdown-editor": "^0.2.23"
  }
}
